# Public (browser)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server only — never expose to the client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Vercel cron auth (optional locally; required in production)
CRON_SECRET=your-cron-secret

# Stripe (Slice 9 — optional locally until billing is enabled)
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRICE_PLUS_MONTHLY=price_your-monthly-id
STRIPE_PRICE_PLUS_ANNUAL=price_your-annual-id

# CI / local build without full env
# SKIP_ENV_VALIDATION=true

# Observability (optional — no-op when unset)
# NEXT_PUBLIC_POSTHOG_KEY=phc_your-key
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# SENTRY_DSN=https://your-sentry-dsn
# NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn

# Playwright E2E
# PLAYWRIGHT_BASE_URL=http://localhost:3000

# Staging (Vercel + staging.samelobby.com) — see docs/runbooks/domain-and-staging.md
# NEXT_PUBLIC_SITE_URL=https://staging.samelobby.com
